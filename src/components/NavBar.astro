---
import "../styles/global.css";
---

<div id="nav-bar" class="flex w-full h-16 md:sticky top-0 z-50
gap-0 content-end justify-end
bg-black border-black md:border-b-2 border-b">
    <div id="nav-buttons"
    class="flex justify-self-end text-center gap-0">
        <a id="work-button" href="/" class="bg-lilac border-x md:border-x-2 border-t md:border-t-2 border-solid border-black
        md:w-50 w-24 content-center mt-3 text-left md:px-10 px-2 py-2
        text-black font-fustat font-bold md:text-base text-xs -tracking-default
        hover:mt-1 transition-all duration-300 hover:bg-lavender">
            My Work
        </a>
        <a id="playground-button" href="/playground" class="bg-light-purple border-r md:border-r-2 border-t md:border-t-2 border-solid border-black
        md:w-50 w-24 content-center mt-3 text-left md:px-10 px-2 py-2
        text-black font-fustat font-bold md:text-base text-xs -tracking-default
        hover:mt-1 transition-all duration-300 hover:bg-lavender">
            Playground
        </a>
        <a id="about-button" href="/about" class="bg-white border-r md:border-r-2 border-t md:border-t-2 border-solid border-black
        md:w-50 w-24 content-center mt-3 text-left md:px-10 px-2 py-2
        text-black font-fustat font-bold md:text-base text-xs -tracking-default
        hover:mt-1 transition-all duration-300 hover:bg-lavender">
            About Me
        </a>
    </div>
</div>